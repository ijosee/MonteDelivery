{
  "name": "pueblo-delivery",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@8.7.4",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:integration": "vitest --run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "seed": "tsx scripts/seed.ts",
    "gen:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > src/types/database.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@sentry/nextjs": "^10.48.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "fast-check": "^4.6.0",
    "jsdom": "^29.0.2",
    "supabase": "^2.92.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
