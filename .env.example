# ═══════════════════════════════════════════════════════════════
# Pueblo Delivery — Variables de entorno
# ═══════════════════════════════════════════════════════════════
# Copia este archivo como .env y rellena los valores:
#   cp .env.example .env

# ─── Base de datos (Supabase Postgres) ────────────────────────
# Local development (Supabase local via Docker)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
# Remote (Supabase cloud — for production)
# DATABASE_URL="postgresql://postgres.[TU-REF]:[TU-PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres"

# ─── Auth.js / NextAuth ──────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="genera-un-secret-aqui"

# ─── Google OAuth (opcional) ─────────────────────────────────
# Crear en: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── CartoCiudad (gratuito, sin API key) ─────────────────────
CARTOCIUDAD_BASE_URL="https://www.cartociudad.es/geocoder/api/geocoder"

# ─── Cloudflare R2 (opcional en desarrollo) ──────────────────
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET_NAME="pueblo-delivery"
CLOUDFLARE_R2_ENDPOINT=""
CLOUDFLARE_R2_PUBLIC_URL=""

# ─── Email — Resend (opcional en desarrollo) ─────────────────
# En dev los emails se muestran en la consola del servidor
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Pueblo Delivery <noreply@pueblodelivery.es>"

# ─── Sentry (opcional en desarrollo) ─────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
